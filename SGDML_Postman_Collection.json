            },
            "url": {
              "raw": "{{base_url}}/api/areas",
              "host": ["{{base_url}}"],
              "path": ["api", "areas"]
            },
            "description": "Registra una nueva área/gerencia. Solo rol `admin`."
          }
        },
        {
          "name": "Actualizar área (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Gerencia de Infraestructura y Desarrollo Urbano\",\n  \"gerencia\": \"Alcaldía\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/areas/{{area_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "areas", "{{area_id}}"]
            },
            "description": "Actualiza los datos de un área. Solo rol `admin`."
          }
        },
        {
          "name": "Eliminar área (admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/areas/{{area_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "areas", "{{area_id}}"]
            },
            "description": "Borrado lógico de un área. Solo rol `admin`."
          }
        }
      ]
    },
    {
      "name": "👤 Usuarios",
      "item": [
        {
          "name": "Listar usuarios (admin/funcionario)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/usuarios",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios"]
            },
            "description": "Lista todos los usuarios del sistema. Accesible para roles `admin` y `funcionario`."
          }
        },
        {
          "name": "Asignar área a un funcionario (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"area_id\": \"{{area_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/usuarios/{{usuario_id}}/area",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios", "{{usuario_id}}", "area"]
            },
            "description": "Asigna (o desasigna, enviando `area_id: null`) un área a un funcionario. Solo rol `admin`."
          }
        },
        {
          "name": "Desactivar usuario (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/usuarios/{{usuario_id}}/desactivar",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios", "{{usuario_id}}", "desactivar"]
            },
            "description": "Borrado lógico de un usuario (lo marca como inactivo). Solo rol `admin`."
          }
        },
        {
          "name": "Reactivar usuario (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/usuarios/{{usuario_id}}/reactivar",
              "host": ["{{base_url}}"],
              "path": ["api", "usuarios", "{{usuario_id}}", "reactivar"]
            },
            "description": "Reactiva un usuario previamente desactivado. Solo rol `admin`."
          }
        }
      ]
    },
    {
      "name": "🔔 Notificaciones",
      "item": [
        {
          "name": "Obtener mis notificaciones",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notificaciones",
              "host": ["{{base_url}}"],
              "path": ["api", "notificaciones"]
            },
            "description": "Retorna todas las notificaciones del usuario autenticado (filtrado automáticamente por JWT)."
          }
        },
        {
          "name": "Marcar notificación como leída",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notificaciones/{{notificacion_id}}/leido",
              "host": ["{{base_url}}"],
              "path": ["api", "notificaciones", "{{notificacion_id}}", "leido"]
            },
            "description": "Marca una notificación específica como leída. Solo el propietario puede marcarla."
          }
        }
      ]
    },
    {
      "name": "📊 Dashboard",
      "item": [
        {
          "name": "Obtener KPIs gerenciales",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard/kpis",
              "host": ["{{base_url}}"],
              "path": ["api", "dashboard", "kpis"]
            },
            "description": "Retorna métricas globales: expedientes totales, tiempo promedio de resolución, tasa de silencio administrativo. Roles: `funcionario`, `admin`."
          }
        },
        {
          "name": "Listar expedientes críticos (semáforo rojo)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard/expedientes-criticos",
              "host": ["{{base_url}}"],
              "path": ["api", "dashboard", "expedientes-criticos"]
            },
            "description": "Lista los expedientes que vencen en menos de 3 días hábiles (semáforo rojo). Ordenados por `score_prioridad DESC`. Roles: `funcionario`, `admin`."
          }
        }
      ]
    },
    {
      "name": "🤖 Webhook — Microservicio IA",
      "item": [
        {
          "name": "Recibir resultado ML (interno)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expediente_id\": \"{{expediente_id}}\",\n  \"tupa_id\": \"{{tupa_id}}\",\n  \"codigo_tupa\": \"TUPA-001\",\n  \"area_asignada_id\": \"{{area_id}}\",\n  \"ia_confianza\": 0.87,\n  \"score_prioridad\": 65.5,\n  \"texto_extraido\": \"Solicitud de licencia de edificación para construcción de vivienda unifamiliar en la urbanización Los Pinos...\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/ml-resultado",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "ml-resultado"]
            },
            "description": "⚙️ Endpoint interno. Normalmente lo llama el Celery Worker del microservicio Python al terminar el OCR + clasificación. Se puede probar manualmente para simular el resultado de la IA. Actualiza el expediente con la clasificación TUPA, área asignada y score de prioridad."
          }
        }
      ]
    },
    {
      "name": "🐍 Microservicio IA (FastAPI)",
      "item": [
        {
          "name": "Clasificar documento manualmente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expediente_id\": \"{{expediente_id}}\",\n  \"texto\": \"Solicito una licencia de edificación para construcción de vivienda unifamiliar con un área de 120 m2\"\n}"
            },
            "url": {
              "raw": "{{python_url}}/ml/clasificar",
              "host": ["{{python_url}}"],
              "path": ["ml", "clasificar"]
            },
            "description": "Envía texto directamente al microservicio Python para clasificación TUPA manual. Retorna tupa_id, area_asignada_id, ia_confianza y score_prioridad."
          }
        },
        {
          "name": "Calcular prioridad manualmente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expediente_id\": \"{{expediente_id}}\",\n  \"fecha_ingreso\": \"2026-05-15T08:00:00\",\n  \"dias_plazo_legal\": 15\n}"
            },
            "url": {
              "raw": "{{python_url}}/ml/priorizar",
              "host": ["{{python_url}}"],
              "path": ["ml", "priorizar"]
            },
            "description": "Calcula el score_prioridad de un expediente dado su fecha de ingreso y el plazo legal del trámite TUPA asignado."
          }
        }
      ]
    }
  ]
}
