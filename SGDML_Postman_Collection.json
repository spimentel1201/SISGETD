{
  "info": {
    "_postman_id": "sgdml-collection-v1",
    "name": "SGDML — API Backend (Express + FastAPI)",
    "description": "Colección completa de endpoints para el Sistema de Gestión Documental con ML — Municipalidad Provincial de Yau.\n\n**Base URL Backend Node:** http://localhost:5000\n**Base URL Microservicio IA:** http://localhost:8000\n\n**Instrucciones:**\n1. Ejecuta primero `POST /api/auth/register` y `POST /api/auth/login`.\n2. Copia el `token` de la respuesta del login.\n3. Pégalo en la variable de colección `{{token}}`.\n4. Todas las rutas protegidas lo usan automáticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "python_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "PEGA_TU_JWT_TOKEN_AQUI", "type": "string" },
    { "key": "expediente_id", "value": "00000000-0000-0000-0000-000000000001", "type": "string" },
    { "key": "tupa_id", "value": "00000000-0000-0000-0000-000000000002", "type": "string" },
    { "key": "area_id", "value": "00000000-0000-0000-0000-000000000003", "type": "string" },
    { "key": "usuario_id", "value": "00000000-0000-0000-0000-000000000004", "type": "string" },
    { "key": "notificacion_id", "value": "00000000-0000-0000-0000-000000000005", "type": "string" }
  ],
  "item": [
    {
      "name": "🏥 Health Checks",
      "item": [
        {
          "name": "Health — Backend (Node)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Comprueba que el servidor Express esté funcionando."
          }
        },
        {
          "name": "Health — Microservicio IA (Python)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{python_url}}/health",
              "host": ["{{python_url}}"],
              "path": ["health"]
            },
            "description": "Comprueba que el servidor FastAPI + Celery esté funcionando."
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Registrar usuario (ciudadano)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dni\": \"12345678\",\n  \"nombre\": \"Juan Pérez García\",\n  \"email\": \"juan.perez@correo.com\",\n  \"password\": \"Password123\",\n  \"telefono\": \"987654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Registra un nuevo ciudadano. Requiere DNI, nombre, email y contraseña (mín. 8 caracteres). Roles disponibles: ciudadano, funcionario, admin."
          }
        },
        {
          "name": "Iniciar sesión (login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.token) pm.collectionVariables.set('token', body.token);",
                  "  console.log('✅ Token guardado correctamente en la variable de colección.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@correo.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Autentica al usuario y retorna un JWT. El test script de Postman guarda el token automáticamente en la variable `{{token}}`."
          }
        }
      ]
    },
    {
      "name": "📁 Expedientes",
      "item": [
        {
          "name": "Crear expediente (con archivo adjunto)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "archivo",
                  "type": "file",
                  "src": [],
                  "description": "PDF, JPEG o PNG. Máximo 20 MB."
                },
                {
                  "key": "asunto",
                  "value": "Solicitud de licencia de edificación para construcción de vivienda unifamiliar",
                  "type": "text"
                },
                {
                  "key": "tupa_id",
                  "value": "{{tupa_id}}",
                  "type": "text",
                  "description": "UUID del procedimiento TUPA obtenido de GET /api/tupa"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/expedientes",
              "host": ["{{base_url}}"],
              "path": ["api", "expedientes"]
            },
            "description": "Crea un nuevo expediente con archivo adjunto (multipart/form-data). El asunto debe tener mínimo 20 caracteres. Requiere autenticación JWT."
          }
        },
        {
          "name": "Listar todos los expedientes (funcionario/admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/expedientes",
              "host": ["{{base_url}}"],
              "path": ["api", "expedientes"]
            },
            "description": "Lista todos los expedientes del sistema. Solo accesible para roles `funcionario` y `admin`."
          }
        },
        {
          "name": "Obtener expediente por ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/expedientes/{{expediente_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "expedientes", "{{expediente_id}}"]
            },
            "description": "Obtiene el detalle completo de un expediente por su UUID. Requiere autenticación."
          }
        },
        {
          "name": "Consultar estado (público, sin login)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/expedientes/{{expediente_id}}/estado?dni=12345678",
              "host": ["{{base_url}}"],
              "path": ["api", "expedientes", "{{expediente_id}}", "estado"],
              "query": [
                {
                  "key": "dni",
                  "value": "12345678",
                  "description": "DNI del titular del expediente. Acceso público sin token."
                }
              ]
            },
            "description": "Endpoint público (no requiere JWT). El ciudadano puede consultar el estado de su trámite usando el número de expediente + DNI."
          }
        },
        {
          "name": "Actualizar estado del expediente (funcionario/admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nuevo_estado\": \"en_evaluacion\",\n  \"observacion\": \"Expediente derivado a Gerencia de Infraestructura para evaluación técnica.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/expedientes/{{expediente_id}}/estado",
              "host": ["{{base_url}}"],
              "path": ["api", "expedientes", "{{expediente_id}}", "estado"]
            },
            "description": "Actualiza el estado del expediente y registra el cambio en historial_estados. Estados válidos: ingresado, en_validacion, requiere_triaje, derivado, en_evaluacion, resuelto, archivado. Solo funcionario/admin."
          }
        }
      ]
    },
    {
      "name": "📋 TUPA — Procedimientos",
      "item": [
        {
          "name": "Listar procedimientos TUPA (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/tupa",
              "host": ["{{base_url}}"],
              "path": ["api", "tupa"]
            },
            "description": "Lista todos los trámites TUPA activos. Endpoint público — el ciudadano lo usa para elegir el tipo de trámite al crear su expediente."
          }
        },
        {
          "name": "Registrar trámite TUPA (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo_tupa\": \"TUPA-006\",\n  \"nombre_tramite\": \"Certificado de Numeración y Nomenclatura\",\n  \"dias_plazo_legal\": 7,\n  \"tipo_silencio\": \"positivo\",\n  \"area_responsable_id\": \"{{area_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tupa",
              "host": ["{{base_url}}"],
              "path": ["api", "tupa"]
            },
            "description": "Registra un nuevo procedimiento en el catálogo TUPA. `tipo_silencio` acepta: positivo, negativo, automatico. Solo rol `admin`."
          }
        },
        {
          "name": "Actualizar trámite TUPA (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_tramite\": \"Certificado de Numeración Oficial\",\n  \"dias_plazo_legal\": 5,\n  \"tipo_silencio\": \"negativo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tupa/{{tupa_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tupa", "{{tupa_id}}"]
            },
            "description": "Actualiza los datos de un trámite TUPA. Solo rol `admin`."
          }
        },
        {
          "name": "Desactivar trámite TUPA (admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/tupa/{{tupa_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tupa", "{{tupa_id}}"]
            },
            "description": "Borrado lógico del trámite TUPA (lo desactiva, no lo elimina físicamente de la BD). Solo rol `admin`."
          }
        }
      ]
    },
    {
      "name": "🏢 Áreas",
      "item": [
        {
          "name": "Listar áreas (público)",
          "request": {
