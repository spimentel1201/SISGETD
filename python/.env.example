# Variables de entorno — SGDML Microservicio Python
# Copiar como .env y completar valores reales

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/sgdml_db

# Redis (broker Celery)
REDIS_URL=redis://localhost:6379/0

# URL del backend Node (para callbacks webhook)
NODE_BACKEND_URL=http://localhost:5000

# Ruta del binario de Tesseract OCR (Windows / Linux)
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Directorio temporal para archivos descargados
TMP_DIR=./tmp
