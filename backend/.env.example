# Variables de entorno — SGDML Backend
# Copiar como .env y completar valores reales

# Servidor
PORT=5000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgdml_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# JWT
JWT_SECRET=cambia_este_secreto_muy_seguro_aqui
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=otro_secreto_para_refresh
JWT_REFRESH_EXPIRES_IN=7d

# RabbitMQ / Redis (Message Broker)
RABBITMQ_URL=amqp://localhost:5672
REDIS_URL=redis://localhost:6379

# Almacenamiento de archivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# Correo (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=notificaciones@municipalidadyau.gob.pe
MAIL_PASS=tu_password_correo

# Microservicio Python (FastAPI)
PYTHON_SERVICE_URL=http://localhost:8000

# URL pública del backend (para webhooks)
BASE_URL=http://localhost:5000
